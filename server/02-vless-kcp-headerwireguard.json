// =============================================================================
// Scenario 2: VLESS+mKCP disguised as WireGuard via FinalMask header-wireguard (Server)
//
// NOT real WireGuard! This uses VLESS protocol over mKCP transport, with
// FinalMask's header-wireguard making every UDP packet look like genuine
// WireGuard traffic. This is useful when:
//   - You want WireGuard-like traffic patterns for camouflage
//   - But need VLESS features (XTLS Vision, REALITY, fallback, etc.)
//   - The transport is mKCP (KCP over UDP) for reliability over lossy links
//
// header-wireguard requires NO additional configuration — it automatically
// prepends/strips a WireGuard-like header to UDP packets.
//
// Replace <UUID> with a real UUID (generated by `xray uuid`).
// =============================================================================

{
  "log": {
    "loglevel": "warning"
  },

  "inbounds": [
    {
      "listen": "0.0.0.0",
      "port": 51820,
      "protocol": "vless",
      "tag": "vless-in",

      "settings": {
        "clients": [
          {
            "id": "<UUID>"
          }
        ],
        "decryption": "none"
      },

      // mKCP transport with WireGuard header camouflage
      "streamSettings": {
        "network": "kcp",
        "kcpSettings": {
          "mtu": 1350,
          "tti": 50,
          "uplinkCapacity": 100,
          "downlinkCapacity": 100,
          "congestion": false,
          "readBufferSize": 2,
          "writeBufferSize": 2,
          "header": {
            "type": "none"    // Use "none" because FinalMask handles headers
          }
        },

        // FinalMask: make mKCP UDP packets look like WireGuard
        "finalmask": {
          "udp": [
            {
              "type": "header-wireguard"
              // No settings needed — header-wireguard is zero-config
            }
          ]
        }
      }
    }
  ],

  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    }
  ]
}
